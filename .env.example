# docker-compose 실행 시 필요한 환경변수
# 이 파일을 복사해서 .env 로 만들고 실제 값으로 채우세요
# cp .env.example .env

MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_USER=skct
MYSQL_PASSWORD=your_mysql_password
JWT_SECRET=your-jwt-secret-key-minimum-256-bits-long

# Grafana 관리자 비밀번호 (기본값: admin)
GRAFANA_PASSWORD=your_grafana_password
